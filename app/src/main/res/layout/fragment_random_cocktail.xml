<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <ScrollView
        android:id="@+id/random_cocktail_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible"
        tools:visibility="visible">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_random_cocktail_image"
                android:layout_width="0dp"
                android:layout_height="300dp"
                android:contentDescription="@string/image_filler"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.None"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:src="@tools:sample/backgrounds/scenic" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/iv_random_cocktail_image">

                <TextView
                    android:id="@+id/tv_random_cocktail_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:textAppearance="?attr/textAppearanceHeadlineMedium"
                    android:textColor="?attr/colorOnSurface"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:text="Old Fashioned" />

                <TextView
                    android:id="@+id/tv_random_cocktail_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="?attr/colorPrimary"
                    app:layout_constraintTop_toBottomOf="@id/tv_random_cocktail_name"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:text="Ordinary Drink" />

                <TextView
                    android:id="@+id/tv_random_cocktail_alcoholic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:alpha="0.7"
                    app:layout_constraintBaseline_toBaselineOf="@id/tv_random_cocktail_category"
                    app:layout_constraintStart_toEndOf="@id/tv_random_cocktail_category"
                    tools:text="• Alcoholic" />

                <TextView
                    android:id="@+id/tv_random_cocktail_glass"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    app:layout_constraintTop_toBottomOf="@id/tv_random_cocktail_category"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:text="Served in: Old Fashioned glass" />

                <TextView
                    android:id="@+id/tv_random_ingredients_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    app:layout_constraintTop_toBottomOf="@id/tv_random_cocktail_glass"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:text="Ingredients" />

                <LinearLayout
                    android:id="@+id/layout_random_ingredients"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/tv_random_ingredients_header"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tv_random_instructions_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    app:layout_constraintTop_toBottomOf="@id/layout_random_ingredients"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:text="Instructions" />

                <TextView
                    android:id="@+id/tv_random_instructions"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:lineSpacingExtra="4dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_random_instructions_header"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:text="Place sugar cube in old fashioned glass and saturate with bitters..." />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_shuffle"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="@string/action_shuffle"
                    app:icon="@drawable/outline_360_24"
                    app:layout_constraintTop_toBottomOf="@id/tv_random_instructions"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <TextView
        android:id="@+id/tv_random_loading_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:padding="32dp"
        android:gravity="center"
        android:textColor="?attr/colorError"
        android:visibility="invisible"
        android:textAppearance="?attr/textAppearanceBodyLarge" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/random_loading_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:visibility="invisible" />

</FrameLayout>